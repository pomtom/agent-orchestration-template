# MCP credentials — copy to .mcp/configurations/.env (gitignored) and fill in.
# NEVER commit real values. Referenced by .mcp.json via ${VAR} placeholders.

# --- Workspace (code-search, architecture-analysis) ---
# Absolute path to the repository root where this framework is installed.
WORKSPACE_ROOT=/absolute/path/to/your/repo

# --- GitHub ---
# PAT with least scopes (repo or public_repo; +workflow / +read:org as needed).
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Azure (azure, application-insights) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
# Full ARM resource ID of the Application Insights resource.
APPLICATIONINSIGHTS_RESOURCE_ID=

# --- Security scanning ---
# Token for your chosen security MCP server (rename to the vendor's expected var if needed).
SECURITY_SCANNER_TOKEN=

# Credential-free servers (no vars needed): documentation-search, dependency-scanning.
